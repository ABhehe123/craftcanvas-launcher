{
  "name": "craftcanvas",
  "productName": "Craft CanvaS",
  "version": "1.0.0",
  "description": "The Ultimate Browserless Minecraft Modding Suite",
  "author": "WatermelonDev",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "minecraft-launcher-core": "^bababbababaeds",
    "msmc": "^idntknow"
  },
  "devDependencies": {
    "electron": "^22.0.0",
    "electron-builder": "^22.9.1"
  },
  "build": {
    "appId": "com.watermelon.craftcanvas",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Craft CanvaS",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
